# Canon Camera Control edge API base URL. Falls back to http://localhost:3000
# if unset -- only needs to be set here when the edge API runs elsewhere (a
# separate Mini PC, a different host/IP on the plant network, etc). If set, it
# must be a valid absolute URL or the app will fail fast at startup/build time.
CAMERA_API_URL=http://10.60.20.196:3000

# Optional bearer token for the edge API. Leave unset if the edge API doesn't
# require auth. Never committed -- only .env.example is tracked in git.
# CAMERA_API_TOKEN=

# Network share captures are saved to automatically (e.g. a mapped/UNC path
# like \\10.1.1.44\Data Analythics\ML\MTI). This app owns this setting, not
# the edge device -- it's sent with every save request, so changing the
# destination folder is a one-line change here with no edge device restart
# needed. Leave unset to disable automatic network saving entirely; captures
# then fall back to the browser folder picker / plain download.
# NETWORK_SAVE_ROOT=\\10.1.1.44\Data Analythics\ML\MTI
