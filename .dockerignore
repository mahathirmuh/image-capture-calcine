# Never ship host node_modules into the image -- they contain platform-native
# binaries built for the host OS (Windows here) and would break in the Linux
# container. The build stage installs its own.
node_modules
**/node_modules

# Build artifacts (the image builds these itself)
.output
.nitro
.tanstack
.wrangler
dist
dist-ssr

# Secrets / local config -- CAMERA_API_URL is injected at runtime via
# docker-compose, never baked into the image.
.env
.env.*
!.env.example
.dev.vars

# VCS / editor / OS noise
.git
.gitignore
.vscode
.idea
.DS_Store
*.log
logs

# Docker's own files
Dockerfile
.dockerignore
docker-compose*.yml

# Docs
*.md
